# ─── Talking BI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values

# ── AI APIs ──────────────────────────────────────────────────────────────
# Anthropic (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Groq (Primary — cheaper LLM for agents)
GROQ_API_KEY=your_groq_api_key_here
# OpenAI (Required for Whisper STT)
OPENAI_API_KEY=your_openai_api_key_here_for_whisper

# ── TTS (Optional — for voice responses) ─────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Your Analytics Database (Optional — demo data used if not set) ────────────
# MySQL:      mysql+aiomysql://username:password@localhost:3306/your_database
# PostgreSQL: postgresql+asyncpg://username:password@localhost:5432/your_database
ANALYTICS_DB_URL=

# ── Redis (Optional — in-memory fallback used if not running) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Power BI (Optional) ───────────────────────────────────────────────────────
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=

# ── Salesforce (Optional) ─────────────────────────────────────────────────────
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# ── Shopify (Optional) ────────────────────────────────────────────────────────
SHOPIFY_SHOP_URL=
SHOPIFY_ACCESS_TOKEN=

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-this-in-production-to-random-string
UPLOAD_DIR=./uploads
